{
  "version": 1,
  "type": "lumiverse_regex_scripts",
  "scripts": [
    {
      "name": "Demo — Interactive Scene Card",
      "script_id": "demo_interactive_scene_card",
      "find_regex": "<scene>\\s*<location>([\\s\\S]*?)<\\/location>\\s*<description>([\\s\\S]*?)<\\/description>\\s*<choice>([\\s\\S]*?)<\\/choice>\\s*<\\/scene>",
      "replace_string": "<style>.lumi-scene-card{position:relative;overflow:hidden;margin:1rem 0;padding:1.15rem;border:1px solid rgba(148,163,184,.32);border-radius:18px;background:linear-gradient(145deg,rgba(30,41,59,.96),rgba(15,23,42,.96));box-shadow:0 18px 45px rgba(2,6,23,.28);color:#e2e8f0}.lumi-scene-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(167,139,250,.22),transparent 42%);pointer-events:none}.lumi-scene-kicker{position:relative;margin:0 0 .35rem;color:#c4b5fd;font-size:.72rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase}.lumi-scene-title{position:relative;margin:0 0 .55rem;font-size:1.25rem;color:#fff}.lumi-scene-copy{position:relative;margin:0 0 1rem;color:#cbd5e1;line-height:1.65}.lumi-scene-choice{position:relative;width:100%;padding:.75rem 1rem;border:1px solid rgba(196,181,253,.45);border-radius:12px;background:rgba(124,58,237,.2);color:#ede9fe;font:inherit;font-weight:700;text-align:left;cursor:pointer;transition:transform .15s ease,background .15s ease}.lumi-scene-choice:hover{transform:translateY(-1px);background:rgba(124,58,237,.34)}.lumi-scene-choice[data-lumiverse-regex-action-used='true']{transform:none;cursor:not-allowed}</style><article class=\"lumi-scene-card\"><p class=\"lumi-scene-kicker\">Current scene</p><h3 class=\"lumi-scene-title\">$1</h3><p class=\"lumi-scene-copy\">$2</p><button type=\"button\" class=\"lumi-scene-choice\" data-regex-action=\"choose-scene\">→ $3</button></article>",
      "actions": [
        {
          "id": "choose-scene",
          "type": "send",
          "multi_select": false,
          "cost": "1",
          "limit": "3",
          "title": "Choose: $3",
          "subtitle": "Scene: $1",
          "content": "I choose to $3."
        }
      ],
      "flags": "gi",
      "placement": ["ai_output"],
      "scope": "global",
      "scope_id": null,
      "target": ["display"],
      "min_depth": null,
      "max_depth": null,
      "trim_strings": [],
      "run_on_edit": true,
      "substitute_macros": "none",
      "disabled": false,
      "sort_order": 0,
      "description": "Turns <scene> output into a visual card with a one-shot visible action.",
      "folder": "Regex Action Demos",
      "metadata": {}
    }
  ],
  "exported_at": 0
}
