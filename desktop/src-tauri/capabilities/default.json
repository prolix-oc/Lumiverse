{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Hidden main window hosting the tray logic",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "core:image:default",
    "store:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://localhost:*" }, { "url": "http://127.0.0.1:*" }]
    }
  ]
}
