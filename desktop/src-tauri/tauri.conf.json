{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumiverse Tray",
  "version": "0.1.0",
  "identifier": "chat.lumiverse.tray",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lumiverse Tray",
        "width": 1,
        "height": 1,
        "x": 0,
        "y": 0,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "focus": false,
        "skipTaskbar": true,
        "alwaysOnBottom": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Menu bar / system tray companion for the Lumiverse server",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
